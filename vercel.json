{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "pnpm run vercel-build",

	"experimentalServices": {
		"frontend": {
			"entrypoint": "frontend",
			"routePrefix": "/",
			"framework": "nextjs"
		},
		"backend": {
			"entrypoint": "backend",
			"routePrefix": "/_/api"
		}
	}
}
